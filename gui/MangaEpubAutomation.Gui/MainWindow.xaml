<Window x:Class="MangaEpubAutomation.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:pages="clr-namespace:MangaEpubAutomation.Gui.Views.Pages"
        mc:Ignorable="d"
        Title="MangaEpubAutomation"
        Width="1500"
        Height="950"
        MinWidth="1250"
        MinHeight="780"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen">
    <ui:NavigationView x:Name="RootNavigation"
                       PaneTitle="MangaEpubAutomation"
                       IsBackButtonVisible="Collapsed"
                       IsPaneToggleVisible="True"
                       IsPaneOpen="True"
                       OpenPaneLength="240"
                       CompactPaneLength="56"
                       PaneDisplayMode="Left">
        <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem Content="Run"
                                   TargetPageType="{x:Type pages:RunPage}" />
            <ui:NavigationViewItem Content="Dependencies"
                                   TargetPageType="{x:Type pages:DependenciesPage}" />
            <ui:NavigationViewItem Content="Pipeline Config"
                                   TargetPageType="{x:Type pages:PipelineConfigPage}" />
            <ui:NavigationViewItem Content="Merge Order"
                                   TargetPageType="{x:Type pages:MergeOrderPage}" />
            <ui:NavigationViewItem Content="Logs &amp; Result"
                                   TargetPageType="{x:Type pages:LogsResultPage}" />
        </ui:NavigationView.MenuItems>

        <ui:NavigationView.FooterMenuItems>
            <ui:NavigationViewItem Content="Theme: Follow System"
                                   Click="OnFollowSystemThemeClick" />
            <ui:NavigationViewItem Content="Theme: Light"
                                   Click="OnLightThemeClick" />
            <ui:NavigationViewItem Content="Theme: Dark"
                                   Click="OnDarkThemeClick" />
        </ui:NavigationView.FooterMenuItems>
    </ui:NavigationView>
</Window>
