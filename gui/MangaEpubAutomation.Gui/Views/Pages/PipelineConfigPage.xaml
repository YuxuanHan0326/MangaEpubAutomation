<Page x:Class="MangaEpubAutomation.Gui.Views.Pages.PipelineConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MangaEpubAutomation.Gui"
      mc:Ignorable="d"
      Title="PipelineConfig">
    <Grid Margin="12">
        <ui:DynamicScrollViewer VerticalScrollBarVisibility="Auto"
                                IsScrollSpillEnabled="True">
            <StackPanel>
                <TextBlock Margin="2,0,0,10"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Title]}" />

                <ui:Card Margin="0,0,0,10" Padding="14">
                    <WrapPanel>
                        <ui:Button Margin="0,0,10,8" Command="{Binding LoadPipelineConfigCommand}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.LoadForm]}" />
                        <ui:Button Margin="0,0,10,8" Command="{Binding SavePipelineConfigCommand}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.SaveForm]}" />
                        <ui:Button Margin="0,0,10,8" Command="{Binding InitPipelineConfigCommand}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.InitViaScript]}" />
                    </WrapPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,10" Padding="14">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,10" FontSize="16" FontWeight="SemiBold" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.PipelineNaming]}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.SourceDirSuffixToSkip]}" />
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4,0,4" Text="{Binding CfgSourceDirSuffixToSkip, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.SourceDirSuffixToSkip]}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.OutputDirSuffix]}" />
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4,0,4" Text="{Binding CfgOutputDirSuffix, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.OutputDirSuffix]}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.EpubOutputDirSuffix]}" />
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4,0,4" Text="{Binding CfgEpubOutputDirSuffix, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.EpubOutputDirSuffix]}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.OutputFilenamePattern]}" />
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,4,0,4" Text="{Binding CfgOutputFilenamePattern, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.OutputFilenamePattern]}" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,10" Padding="14">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,10" FontSize="16" FontWeight="SemiBold" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.MangaSettings]}" />
                        <WrapPanel Margin="0,0,0,8">
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgOverwriteExistingFiles}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.OverwriteExistingFiles]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.OverwriteExistingFiles]}" />
                        </WrapPanel>
                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Width="180" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.UpscaleScaleFactor]}" />
                            <TextBox Width="100"
                                     Text="{Binding CfgUpscaleScaleFactor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.UpscaleScaleFactor]}" />

                            <TextBlock Width="120" Margin="20,0,0,0" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.OutputFormat]}" />
                            <TextBox Width="120" Text="{Binding CfgOutputFormat, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.OutputFormat]}" />
                        </WrapPanel>
                        <WrapPanel>
                            <TextBlock Width="180" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.LossyCompressionQuality]}" />
                            <TextBox Width="100"
                                     Text="{Binding CfgLossyCompressionQuality, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.LossyCompressionQuality]}" />

                        </WrapPanel>
                        <WrapPanel Margin="0,8,0,0">
                            <TextBlock Width="180" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.GrayscaleDetectionThreshold]}" />
                            <TextBox Width="100"
                                     Text="{Binding CfgGrayscaleDetectionThreshold, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.GrayscaleDetectionThreshold]}" />

                        </WrapPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,10" Padding="14">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,10" FontSize="16" FontWeight="SemiBold" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccMain]}" />
                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Width="180" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccDeviceProfile]}" />
                            <TextBox Width="140"
                                     Text="{Binding CfgKccDeviceProfile, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccDeviceProfile]}" />
                            <TextBlock Width="180" Margin="20,0,0,0" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccOutputFormat]}" />
                            <TextBox Width="120"
                                     Text="{Binding CfgKccOutputFormat, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccOutputFormat]}" />
                        </WrapPanel>
                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Width="180" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccTargetSizeMb]}" />
                            <TextBox Width="140"
                                     Text="{Binding CfgKccTargetSizeMb, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccTargetSizeMb]}" />
                        </WrapPanel>
                        <WrapPanel>
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccMangaStyle}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccMangaStyle]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccMangaStyle]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccWebtoonMode}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccWebtoonMode]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccWebtoonMode]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccHighQualityMagnification}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccHighQualityMagnification]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccHighQualityMagnification]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccTwoPanelView}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccTwoPanelView]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccTwoPanelView]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccNoKepub}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccNoKepub]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccNoKepub]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccDisableProcessing}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccDisableProcessing]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccDisableProcessing]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccForceColor}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccForceColor]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccForceColor]}" />
                        </WrapPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,10" Padding="14">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,10" FontSize="16" FontWeight="SemiBold" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccProcessing]}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccDoublePageParser]}" />
                            <ComboBox Grid.Row="0"
                                      Grid.Column="1"
                                      Margin="0,4,16,4"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding CfgKccSplitterMode}"
                                      ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccDoublePageParser]}">
                                <ComboBoxItem Tag="-1" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.DefaultUnset]}" />
                                <ComboBoxItem Tag="0" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Split]}" />
                                <ComboBoxItem Tag="1" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Rotate]}" />
                                <ComboBoxItem Tag="2" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Both]}" />
                            </ComboBox>

                            <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccCroppingMode]}" />
                            <ComboBox Grid.Row="0"
                                      Grid.Column="3"
                                      Margin="0,4,0,4"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding CfgKccCroppingMode}"
                                      ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccCroppingMode]}">
                                <ComboBoxItem Tag="-1" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.DefaultUnset]}" />
                                <ComboBoxItem Tag="0" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Disabled]}" />
                                <ComboBoxItem Tag="1" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Margins]}" />
                                <ComboBoxItem Tag="2" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.MarginsPageNo]}" />
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccGamma]}" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,4,16,4"
                                     Text="{Binding CfgKccGamma, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccGamma]}" />

                            <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccInterPanelCrop]}" />
                            <ComboBox Grid.Row="1"
                                      Grid.Column="3"
                                      Margin="0,4,0,4"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding CfgKccInterPanelCropMode}"
                                      ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccInterPanelCrop]}">
                                <ComboBoxItem Tag="-1" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.DefaultUnset]}" />
                                <ComboBoxItem Tag="0" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Disabled]}" />
                                <ComboBoxItem Tag="1" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Horizontally]}" />
                                <ComboBoxItem Tag="2" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Both]}" />
                            </ComboBox>

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccCroppingPower]}" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="0,4,16,4"
                                     Text="{Binding CfgKccCroppingPower, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccCroppingPower]}" />

                            <TextBlock Grid.Row="2" Grid.Column="2" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccPreserveMarginPercent]}" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="3"
                                     Margin="0,4,0,4"
                                     Text="{Binding CfgKccPreserveMarginPercent, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccPreserveMarginPercent]}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccCroppingMinimumRatio]}" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     Margin="0,4,16,4"
                                     Text="{Binding CfgKccCroppingMinimumRatio, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccCroppingMinimumRatio]}" />

                            <TextBlock Grid.Row="3" Grid.Column="2" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccJpegQuality]}" />
                            <TextBox Grid.Row="3" Grid.Column="3" Margin="0,4,0,4" Text="{Binding CfgKccJpegQuality, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccJpegQuality]}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccImageOutputMode]}" />
                            <ComboBox Grid.Row="4"
                                      Grid.Column="1"
                                      Margin="0,4,16,4"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding CfgKccImageOutputMode}"
                                      ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccImageOutputMode]}">
                                <ComboBoxItem Tag="0" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.ImageModeDefault]}" />
                                <ComboBoxItem Tag="1" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.ImageModePng]}" />
                                <ComboBoxItem Tag="2" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.ImageModeMozJpeg]}" />
                            </ComboBox>
                        </Grid>
                        <WrapPanel Margin="0,8,0,0">
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccUpscaleSmallImages}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccUpscaleSmallImages]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccUpscaleSmallImages]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccStretchToResolution}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccStretchToResolution]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccStretchToResolution]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccForceBlackBorders}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccForceBlackBorders]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccForceBlackBorders]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccForceWhiteBorders}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccForceWhiteBorders]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccForceWhiteBorders]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccMaximizeStrips}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccMaximizeStrips]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccMaximizeStrips]}" />
                        </WrapPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,10" Padding="14">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,10" FontSize="16" FontWeight="SemiBold" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccPost]}" />
                        <WrapPanel Margin="0,8,0,0">
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccSpreadShift}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccSpreadShift]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccSpreadShift]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccNoRotateSpreads}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccNoRotateSpreads]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccNoRotateSpreads]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccRotateFirstSpread}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccRotateFirstSpread]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccRotateFirstSpread]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccAutoLevel}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccAutoLevel]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccAutoLevel]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccDisableAutoContrast}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccDisableAutoContrast]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccDisableAutoContrast]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccColorAutoContrast}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccColorAutoContrast]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccColorAutoContrast]}" />
                            <CheckBox Margin="0,0,16,8" IsChecked="{Binding CfgKccEraseRainbow}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.KccEraseRainbow]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.KccEraseRainbow]}" />
                        </WrapPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,10" Padding="14">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,10" FontSize="16" FontWeight="SemiBold" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.MergeMetadata]}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Language]}" />
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4,0,4" Text="{Binding CfgMergeLanguage, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.Language]}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.DescriptionHeader]}" />
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4,0,4" Text="{Binding CfgMergeDescriptionHeader, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.DescriptionHeader]}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.MetadataContributor]}" />
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4,0,4" Text="{Binding CfgMergeMetadataContributor, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.MetadataContributor]}" />

                            <CheckBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" IsChecked="{Binding CfgMergeIncludeOrderInDescription}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.IncludeOrderInDescription]}" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Cfg.Tip.IncludeOrderInDescription]}" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <Expander Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Common.AdvancedJsonEditor]}" IsExpanded="False">
                    <ui:Card Margin="0,8,0,0" Padding="14">
                        <StackPanel>
                            <WrapPanel>
                                <ui:Button Margin="0,0,10,8" Command="{Binding LoadPipelineConfigCommand}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Common.ReloadJson]}" />
                                <ui:Button Margin="0,0,10,8" Command="{Binding SavePipelineConfigRawJsonCommand}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Common.SaveJsonRaw]}" />
                            </WrapPanel>
                            <TextBox Margin="0,8,0,0"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     Text="{Binding PipelineConfigJsonText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas"
                                     FontSize="13" />
                        </StackPanel>
                    </ui:Card>
                </Expander>
            </StackPanel>
        </ui:DynamicScrollViewer>
    </Grid>
</Page>
