<Page x:Class="MangaEpubAutomation.Gui.Views.Pages.EpubPipelinePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MangaEpubAutomation.Gui"
      mc:Ignorable="d"
      Title="EpubPipeline">
    <Grid Margin="12">
        <ui:DynamicScrollViewer VerticalScrollBarVisibility="Auto"
                                IsScrollSpillEnabled="True">
            <StackPanel>
                <TextBlock Margin="2,0,0,10"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Title]}" />

                <ui:Card Margin="0,0,0,10" Padding="14">
                    <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.SharedSettingsNotice]}"
                               TextWrapping="Wrap" />
                </ui:Card>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:Card Grid.Column="0" Margin="0,0,6,0" Padding="14">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,8">
                                <TextBlock Width="170"
                                           VerticalAlignment="Center"
                                           Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.InputMode]}"
                                           ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.InputMode]}" />
                                <ComboBox Width="230" SelectedValuePath="Tag" SelectedValue="{Binding EpubInputMode}">
                                    <ComboBoxItem Tag="0" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.InputMode.Files]}" />
                                    <ComboBoxItem Tag="1" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.InputMode.Directory]}" />
                                </ComboBox>
                            </WrapPanel>

                            <TextBlock Margin="0,4,0,6"
                                       FontWeight="SemiBold"
                                       Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.InputFiles]}"
                                       ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.InputFiles]}" />
                            <WrapPanel Margin="0,0,0,8">
                                <ui:Button Margin="0,0,10,8"
                                           Command="{Binding BrowseEpubInputFilesCommand}"
                                           Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.AddFiles]}"
                                           ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.InputFiles]}" />
                                <ui:Button Margin="0,0,10,8"
                                           Command="{Binding RemoveEpubInputFileCommand}"
                                           Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.RemoveFile]}"
                                           ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.InputFiles]}" />
                                <ui:Button Margin="0,0,10,8"
                                           Command="{Binding ClearEpubInputFilesCommand}"
                                           Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.ClearFiles]}"
                                           ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.InputFiles]}" />
                            </WrapPanel>
                            <ListBox Height="170"
                                      ItemsSource="{Binding EpubInputFiles}"
                                      SelectedItem="{Binding SelectedEpubInputFile, Mode=TwoWay}"
                                      ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.InputFiles]}" />

                            <TextBlock Margin="0,10,0,6"
                                       FontWeight="SemiBold"
                                       Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.InputDirectory]}"
                                       ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.InputDirectory]}" />
                            <WrapPanel>
                                <TextBox Width="500"
                                         Margin="0,0,10,8"
                                         Text="{Binding EpubInputDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.InputDirectory]}" />
                                <ui:Button Margin="0,0,0,8"
                                           Command="{Binding BrowseEpubInputDirectoryCommand}"
                                           Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.BrowseDirectory]}"
                                           ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.InputDirectory]}" />
                            </WrapPanel>
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Grid.Column="1" Margin="6,0,0,0" Padding="14">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,8">
                                <TextBlock Width="170"
                                           VerticalAlignment="Center"
                                           Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.OutputDirectory]}" />
                                <TextBox Width="360"
                                         Margin="0,0,10,0"
                                         Text="{Binding EpubOutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.OutputDirectory]}" />
                                <ui:Button Command="{Binding BrowseEpubOutputDirectoryCommand}"
                                           Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Common.Browse]}"
                                           ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.OutputDirectory]}" />
                            </WrapPanel>
                            <WrapPanel Margin="0,0,0,8">
                                <TextBlock Width="170" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.OutputSuffix]}" />
                                <TextBox Width="200"
                                         Text="{Binding EpubOutputSuffix, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.OutputSuffix]}" />
                            </WrapPanel>
                            <WrapPanel Margin="0,0,0,8">
                                <CheckBox Margin="0,0,16,8"
                                          IsChecked="{Binding EpubOverwriteOutputEpub}"
                                          Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Overwrite]}"
                                          ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.Overwrite]}" />
                            </WrapPanel>

                            <WrapPanel Margin="0,0,0,8">
                                <TextBlock Width="170" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.UpscaleFactor]}" />
                                <ComboBox Width="110"
                                          ItemsSource="{Binding UpscaleFactorOptions}"
                                          SelectedItem="{Binding UpscaleFactor}"
                                          ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.UpscaleFactor]}" />
                                <TextBlock Width="140" Margin="20,0,0,0" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.LossyQuality]}" />
                                <TextBox Width="100"
                                         Text="{Binding LossyQuality, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.LossyQuality]}" />
                            </WrapPanel>

                            <WrapPanel Margin="0,0,0,8">
                                <TextBlock Width="170" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.GrayThreshold]}" />
                                <TextBox Width="110"
                                         Text="{Binding CfgGrayscaleDetectionThreshold, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.GrayThreshold]}" />
                                <TextBlock Width="140" Margin="20,0,0,0" VerticalAlignment="Center" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.LogLevel]}" />
                                <ComboBox Width="110"
                                          ItemsSource="{Binding LogLevelOptions}"
                                          SelectedItem="{Binding LogLevel}"
                                          ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.LogLevel]}" />
                            </WrapPanel>

                            <WrapPanel Margin="0,0,0,8">
                                <CheckBox Margin="0,0,16,8"
                                          IsChecked="{Binding DryRun}"
                                          Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Run.DryRun]}"
                                          ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.DryRun]}" />
                                <CheckBox Margin="0,0,16,8"
                                          IsChecked="{Binding FailOnPreflightWarnings}"
                                          Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Run.FailOnWarnings]}"
                                          ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Epub.Tip.FailOnWarnings]}" />
                            </WrapPanel>

                            <WrapPanel Margin="0,6,0,0">
                                <ui:Button Margin="0,0,10,8" Command="{Binding GenerateEpubPlanCommand}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Run.GeneratePlan]}" />
                                <ui:Button Margin="0,0,10,8" Appearance="Primary" Command="{Binding ExecuteEpubRunCommand}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Run.RunPipeline]}" />
                                <ui:Button Margin="0,0,10,8" Command="{Binding CancelRunCommand}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Run.Cancel]}" />
                                <ui:Button Margin="0,0,10,8" Command="{Binding LoadLatestEpubArtifactsCommand}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Run.LoadLatestArtifacts]}" />
                            </WrapPanel>
                        </StackPanel>
                    </ui:Card>
                </Grid>

                <ui:Card Margin="0,0,0,10" Padding="14">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,8" FontSize="16" FontWeight="SemiBold" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Run.LiveProgress]}" />
                        <TextBlock Margin="0,0,0,6" Text="{Binding EpubPreflightSummaryText}" />
                        <TextBlock Margin="0,0,0,6" Text="{Binding EpubRunStatusText}" />
                        <TextBlock Text="{Binding EpubFileStatusText}" />
                        <ProgressBar Height="14" Margin="0,4,0,0" Minimum="0" Maximum="100" Value="{Binding EpubFilePercent}" />
                    </StackPanel>
                </ui:Card>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:Card Grid.Column="0" Margin="0,0,6,0" Padding="14" Height="300" VerticalAlignment="Top">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Margin="0,0,0,8" FontSize="16" FontWeight="SemiBold" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Run.PreflightIssues]}" />
                            <DataGrid Grid.Row="1" ItemsSource="{Binding EpubPreflightIssues}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Common.Severity]}" Binding="{Binding Severity}" Width="100" />
                                    <DataGridTextColumn Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Common.Code]}" Binding="{Binding Code}" Width="170" />
                                    <DataGridTextColumn Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Common.Message]}" Binding="{Binding Message}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </ui:Card>

                    <ui:Card Grid.Column="1" Margin="6,0,0,0" Padding="14" Height="300" VerticalAlignment="Top">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Margin="0,0,0,8" FontSize="16" FontWeight="SemiBold" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Logs.LiveLog]}" />
                            <TextBox Grid.Row="1"
                                     Text="{Binding EpubLiveLogText}"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" />
                        </Grid>
                    </ui:Card>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:Card Grid.Column="0" Margin="0,0,6,0" Padding="14" Height="260" VerticalAlignment="Top">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Margin="0,0,0,8" FontSize="16" FontWeight="SemiBold" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Logs.PlanJson]}" />
                            <TextBox Grid.Row="1"
                                     Text="{Binding EpubPlanJsonPreview}"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" />
                        </Grid>
                    </ui:Card>

                    <ui:Card Grid.Column="1" Margin="6,0,0,0" Padding="14" Height="260" VerticalAlignment="Top">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Margin="0,0,0,8" FontSize="16" FontWeight="SemiBold" Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Logs.ResultJson]}" />
                            <TextBox Grid.Row="1"
                                     Text="{Binding EpubResultJsonPreview}"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" />
                        </Grid>
                    </ui:Card>
                </Grid>
            </StackPanel>
        </ui:DynamicScrollViewer>
    </Grid>
</Page>
