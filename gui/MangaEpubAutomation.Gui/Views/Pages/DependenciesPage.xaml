<Page x:Class="MangaEpubAutomation.Gui.Views.Pages.DependenciesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:behaviors="clr-namespace:MangaEpubAutomation.Gui.Behaviors"
      mc:Ignorable="d"
      Title="Dependencies">
    <Grid Margin="12">
        <ui:DynamicScrollViewer VerticalScrollBarVisibility="Auto"
                                IsScrollSpillEnabled="True">
            <StackPanel>
                <TextBlock Margin="2,0,0,10"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Text="Dependencies" />

                <ui:Card Margin="0,0,0,10" Padding="14">
                    <WrapPanel>
                        <ui:Button Margin="0,0,10,8" Command="{Binding LoadDependenciesCommand}" Content="Load Form" />
                        <ui:Button Margin="0,0,10,8" Command="{Binding SaveDependenciesCommand}" Content="Save Form" />
                        <ui:Button Margin="0,0,10,8" Command="{Binding InitDependenciesFromTemplateCommand}" Content="Init From Template" />
                    </WrapPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,10" Padding="14">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,10" FontSize="16" FontWeight="SemiBold" Text="Dependency Paths" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="python_exe" />
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4,8,4" Text="{Binding DepsPythonExe, UpdateSourceTrigger=PropertyChanged}" ToolTip="Path to python executable used by MangaJaNai backend." />
                            <ui:Button Grid.Row="0" Grid.Column="2" Margin="0,4,0,4" Command="{Binding BrowseDepsPythonExeCommand}" Content="Browse" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="backend_script" />
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4,8,4" Text="{Binding DepsBackendScript, UpdateSourceTrigger=PropertyChanged}" ToolTip="Path to run_upscale.py." />
                            <ui:Button Grid.Row="1" Grid.Column="2" Margin="0,4,0,4" Command="{Binding BrowseDepsBackendScriptCommand}" Content="Browse" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="models_dir" />
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4,8,4" Text="{Binding DepsModelsDir, UpdateSourceTrigger=PropertyChanged}" ToolTip="Path to MangaJaNai models directory." />
                            <ui:Button Grid.Row="2" Grid.Column="2" Margin="0,4,0,4" Command="{Binding BrowseDepsModelsDirCommand}" Content="Browse" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,8,8" VerticalAlignment="Center" Text="kcc_exe" />
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,4,8,4" Text="{Binding DepsKccExe, UpdateSourceTrigger=PropertyChanged}" ToolTip="Path to KCC executable." />
                            <ui:Button Grid.Row="3" Grid.Column="2" Margin="0,4,0,4" Command="{Binding BrowseDepsKccExeCommand}" Content="Browse" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,10" Padding="14">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,10" FontSize="16" FontWeight="SemiBold" Text="Progress Settings" />
                        <WrapPanel Margin="0,0,0,8">
                            <CheckBox Margin="0,0,16,8"
                                      IsChecked="{Binding DepsProgressEnabled}"
                                      Content="enabled"
                                      ToolTip="Enable realtime progress display in CLI." />
                        </WrapPanel>
                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Width="220" VerticalAlignment="Center" Text="refresh_seconds" />
                            <TextBox Width="100"
                                     Text="{Binding DepsRefreshSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     behaviors:NumericTextBoxWheelBehavior.IsEnabled="True"
                                     behaviors:NumericTextBoxWheelBehavior.Minimum="1"
                                     behaviors:NumericTextBoxWheelBehavior.Maximum="60" />
                        </WrapPanel>
                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Width="220" VerticalAlignment="Center" Text="eta_min_samples" />
                            <TextBox Width="100"
                                     Text="{Binding DepsEtaMinSamples, UpdateSourceTrigger=PropertyChanged}"
                                     behaviors:NumericTextBoxWheelBehavior.IsEnabled="True"
                                     behaviors:NumericTextBoxWheelBehavior.Minimum="1"
                                     behaviors:NumericTextBoxWheelBehavior.Maximum="1000" />
                        </WrapPanel>
                        <WrapPanel>
                            <TextBlock Width="220" VerticalAlignment="Center" Text="noninteractive_log_interval_seconds" />
                            <TextBox Width="100"
                                     Text="{Binding DepsNoninteractiveLogIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     behaviors:NumericTextBoxWheelBehavior.IsEnabled="True"
                                     behaviors:NumericTextBoxWheelBehavior.Minimum="1"
                                     behaviors:NumericTextBoxWheelBehavior.Maximum="3600" />
                        </WrapPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,10" Padding="14">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,10" FontSize="16" FontWeight="SemiBold" Text="Dependency Repositories" />
                        <WrapPanel>
                            <ui:Button Margin="0,0,10,8" Command="{Binding OpenMangaJaNaiRepoCommand}" Content="MangaJaNaiConverterGui Repo" />
                            <ui:Button Margin="0,0,10,8" Command="{Binding OpenKccRepoCommand}" Content="KCC Repo" />
                            <ui:Button Margin="0,0,10,8" Command="{Binding OpenCopyMangaDownloaderRepoCommand}" Content="CopyManga Downloader Repo" />
                        </WrapPanel>
                    </StackPanel>
                </ui:Card>

                <Expander Header="Advanced JSON Editor" IsExpanded="False">
                    <ui:Card Margin="0,8,0,0" Padding="14">
                        <StackPanel>
                            <WrapPanel>
                                <ui:Button Margin="0,0,10,8" Command="{Binding LoadDependenciesCommand}" Content="Reload JSON" />
                                <ui:Button Margin="0,0,10,8" Command="{Binding SaveDependenciesRawJsonCommand}" Content="Save JSON Raw" />
                            </WrapPanel>
                            <TextBox Margin="0,8,0,0"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     Text="{Binding DepsJsonText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas"
                                     FontSize="13" />
                        </StackPanel>
                    </ui:Card>
                </Expander>
            </StackPanel>
        </ui:DynamicScrollViewer>
    </Grid>
</Page>
