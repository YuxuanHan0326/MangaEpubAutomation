<Page x:Class="MangaEpubAutomation.Gui.Views.Pages.LogsResultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MangaEpubAutomation.Gui"
      mc:Ignorable="d"
      Title="LogsAndResult">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="2,0,0,10"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Logs.Title]}" />

        <ui:Card Grid.Row="1" Margin="0,0,0,10" Padding="14">
            <WrapPanel>
                <ui:Button Margin="0,0,10,8" Command="{Binding ClearLogsCommand}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Logs.Clear]}" />
                <ui:Button Margin="0,0,10,8" Command="{Binding LoadLatestPlanCommand}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Logs.LoadLatestPlan]}" />
                <ui:Button Margin="0,0,10,8" Command="{Binding LoadLatestResultCommand}" Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Logs.LoadLatestResult]}" />
                <TextBlock VerticalAlignment="Center" Text="{Binding LastResultPath}" />
            </WrapPanel>
        </ui:Card>

        <ui:Card Grid.Row="2" Padding="14">
            <TabControl>
                <TabItem Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Logs.LiveLog]}">
                    <TextBox Margin="0,8,0,0"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Text="{Binding LiveLogText}"
                             FontFamily="Consolas"
                             FontSize="12" />
                </TabItem>
                <TabItem Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Logs.PlanJson]}">
                    <TextBox Margin="0,8,0,0"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Text="{Binding PlanJsonPreview}"
                             FontFamily="Consolas"
                             FontSize="11" />
                </TabItem>
                <TabItem Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Logs.ResultJson]}">
                    <TextBox Margin="0,8,0,0"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Text="{Binding ResultJsonPreview}"
                             FontFamily="Consolas"
                             FontSize="11" />
                </TabItem>
            </TabControl>
        </ui:Card>
    </Grid>
</Page>
